{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Live Server (auto-reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", ".", "--port=5500", "--open=index.html"],
      "port": 5500
    },
    {
      "name": "serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen=3000"],
      "port": 3000
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
